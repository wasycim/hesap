{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/admin-digest?interval=daily",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/admin-digest?interval=weekly",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/attendance-alerts",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/backup?interval=daily",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/api/cron/backup?interval=weekly",
      "schedule": "15 1 * * 0"
    },
    {
      "path": "/api/cron/backup?interval=monthly",
      "schedule": "15 1 1 * *"
    }
  ]
}
