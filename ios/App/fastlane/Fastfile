require "json"

default_platform(:ios)

def required_env!(name)
  value = ENV[name].to_s.strip
  UI.user_error!("#{name} ortam değişkeni eksik.") if value.empty?
  value
end

platform :ios do
  desc "Build Hesap iOS and upload it to TestFlight"
  lane :beta do
    bundle_id = ENV.fetch("IOS_BUNDLE_ID", "wasy.system.hesap")
    team_id = required_env!("IOS_TEAM_ID")
    profile_name = required_env!("IOS_PROVISIONING_PROFILE_NAME")
    package_json = JSON.parse(File.read("../../package.json"))
    marketing_version = ENV["IOS_MARKETING_VERSION"].to_s.strip
    marketing_version = package_json.fetch("version") if marketing_version.empty?
    build_number = ENV["IOS_BUILD_NUMBER"].to_s.strip
    build_number = Time.now.utc.strftime("%Y%m%d%H%M") if build_number.empty?
    changelog = ENV["TESTFLIGHT_CHANGELOG"].to_s.strip
    changelog = "Hesap iOS beta güncellemesi." if changelog.empty?

    api_key = app_store_connect_api_key(
      key_id: required_env!("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: required_env!("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: required_env!("APP_STORE_CONNECT_API_PRIVATE_KEY_BASE64"),
      is_key_content_base64: true,
      duration: 1200,
      in_house: false
    )

    increment_version_number(
      xcodeproj: "App.xcodeproj",
      version_number: marketing_version
    )

    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: build_number
    )

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      clean: true,
      output_directory: "../../build/ios",
      output_name: "Hesap.ipa",
      export_method: "app-store",
      xcargs: [
        "DEVELOPMENT_TEAM=#{team_id}",
        "PRODUCT_BUNDLE_IDENTIFIER=#{bundle_id}",
        "CODE_SIGN_STYLE=Manual",
        "CODE_SIGN_IDENTITY=\"Apple Distribution\"",
        "PROVISIONING_PROFILE_SPECIFIER=\"#{profile_name}\""
      ].join(" "),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        manageAppVersionAndBuildNumber: false,
        provisioningProfiles: {
          bundle_id => profile_name
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: bundle_id,
      ipa: "../../build/ios/Hesap.ipa",
      changelog: changelog,
      skip_waiting_for_build_processing: true
    )
  end
end

