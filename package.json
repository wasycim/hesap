{
  "name": "hesap",
  "version": "0.1.8",
  "private": true,
  "license": "UNLICENSED",
  "description": "Hesap web ve QR mesai takip sistemi",
  "main": "electron/main.js",
  "author": "wasycim",
  "repository": {
    "type": "git",
    "url": "https://github.com/wasycim/hesap.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "desktop:icons": "node scripts/create-desktop-icon.js",
    "desktop:dev": "npm run desktop:icons && electron .",
    "desktop:pack": "npm run desktop:icons && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64 --dir",
    "desktop:dist": "npm run desktop:icons && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --x64 --publish never",
    "desktop:publish": "npm run desktop:icons && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --x64 --publish always",
    "mobile:assets": "node scripts/create-mobile-assets.js",
    "mobile:sync": "npm run mobile:assets && cap sync",
    "mobile:open:android": "npm run mobile:sync && cap open android",
    "mobile:open:ios": "npm run mobile:sync && cap open ios",
    "supabase:auth-config": "node scripts/update-supabase-auth-config.mjs",
    "supabase:system-schema": "node scripts/apply-system-operations-schema.js",
    "supabase:push-audit-schema": "node scripts/apply-push-and-advanced-log-schema.js",
    "supabase:notification-rules-schema": "node scripts/apply-notification-rules-schema.js",
    "supabase:advanced-ops-schema": "node scripts/apply-advanced-operations-schema.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed"
  },
  "build": {
    "appId": "wasy.system.hesap",
    "productName": "Hesap",
    "copyright": "Copyright © 2026 Hesap",
    "artifactName": "Hesap-Setup-${version}.${ext}",
    "afterPack": "scripts/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "directories": {
      "buildResources": "desktop/build",
      "output": "desktop/release"
    },
    "files": [
      "electron/**/*",
      "desktop/build/icon.ico",
      "desktop/build/icon.png",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "icon": "desktop/build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "include": "desktop/build/installer.nsh",
      "installerIcon": "desktop/build/icon.ico",
      "uninstallerIcon": "desktop/build/icon.ico",
      "installerHeaderIcon": "desktop/build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hesap"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "wasycim",
        "repo": "hesap"
      }
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.18.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "1.6.1",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "8.6.0",
    "html5-qrcode": "^2.3.8",
    "input-otp": "1.4.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.564.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.10",
    "prisma": "^6.18.0",
    "qrcode": "^1.5.4",
    "react": "^19",
    "react-day-picker": "9.13.2",
    "react-dom": "^19",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  }
}
