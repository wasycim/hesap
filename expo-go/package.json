{
  "name": "hesap-expo-go",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --tunnel",
    "start:lan": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "eas:login": "eas login",
    "eas:whoami": "eas whoami",
    "eas:init": "eas init",
    "eas:configure": "eas build:configure",
    "eas:credentials:ios": "eas credentials -p ios",
    "eas:build:ios": "eas build --platform ios --profile production",
    "eas:submit:ios": "eas submit --platform ios --latest --profile production",
    "eas:testflight": "eas build --platform ios --profile production --auto-submit"
  },
  "dependencies": {
    "expo": "^57.0.1",
    "expo-status-bar": "^57.0.0",
    "react": "19.2.3",
    "react-native": "^0.86.0",
    "react-native-webview": "13.16.1"
  },
  "overrides": {
    "@xmldom/xmldom": "0.9.10",
    "ajv": "8.20.0",
    "diff": "9.0.0",
    "joi": "18.2.3",
    "minimatch": "10.2.5",
    "node-forge": "1.4.0",
    "tar": "7.5.19",
    "ts-deepmerge": "8.0.0",
    "uuid": "11.1.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "eas-cli": "^20.5.0"
  }
